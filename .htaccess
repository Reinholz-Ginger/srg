Options -Indexes
ServerSignature Off

<FilesMatch "^\.">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<FilesMatch "(^|/)(\.env|composer\.(json|lock)|package(-lock)?\.json|README\.md|checkList\.md|gitattributes|htaccess)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<FilesMatch "\.(sql|bak|backup|old|orig|tmp|log)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Deny from all
  </IfModule>
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule (^|/)(error_log|.*\.log)$ - [F,L,NC]
  RewriteRule (^|/).*\.(sql|bak|backup|old|orig|tmp)$ - [F,L,NC]
  RewriteRule (^|/)\.env.*$ - [F,L,NC]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
